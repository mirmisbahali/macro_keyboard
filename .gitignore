# ── KiCAD ────────────────────────────────────────────────────────────────────
# Auto-save / version history (regenerated by KiCAD automatically)
**/.history/

# KiCAD lock files (created while a file is open)
~*.lck

# Manual backup folders created by KiCAD
**/*-backups/

# Per-user project layout preferences (local state, not design data)
**/*.kicad_prl

# Footprint cache (regenerated on open)
**/fp-info-cache

# Python scripting cache
**/__pycache__/
**/*.pyc

# ── External resources ───────────────────────────────────────────────────────
# Large reference materials / cloned repos (not project source)
Electronics/external_resources/

# ── Fusion 360 ───────────────────────────────────────────────────────────────
# Local export artifacts (designs live in Autodesk cloud)
**/*.f3d

# Fusion lock files
**/*.lock

# ── OS clutter ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Firmware build artifacts (future-proofing) ───────────────────────────────
build/
_build/
*.o
*.a
*.elf
*.map
